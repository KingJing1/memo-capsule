{
  "manifest_version": 3,
  "name": "Memo Capsule",
  "version": "0.3.0",
  "description": "A local-first tool for saving, browsing, and exporting ChatGPT, Claude, and Gemini chats, with a customizable memo surface for a memo, book excerpt, or health tip you provide.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "保存当前对话到本地归档"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
